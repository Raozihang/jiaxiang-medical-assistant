APP_NAME=medical-assistant-backend
APP_ENV=development
APP_PORT=8080
APP_DATA_MODE=db
REPORT_SCHEDULE_RETENTION_DAYS=30
AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_JWT_EXPIRES_IN=7200
AUTH_DOCTOR_ACCOUNT=doctor
AUTH_DOCTOR_PASSWORD=replace-with-doctor-password
AUTH_ADMIN_ACCOUNT=admin
AUTH_ADMIN_PASSWORD=replace-with-admin-password

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=medical_assistant
DB_SSLMODE=disable

# AI (set AI_PROVIDER=bailian to enable LLM, default is rule-based)
AI_PROVIDER=rule
AI_API_KEY=
AI_MODEL=qwen3.5-plus
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Outbound call
OUTBOUND_CALL_PROVIDER=mock
ALIYUN_CALL_ACCESS_KEY_ID=
ALIYUN_CALL_ACCESS_KEY_SECRET=
ALIYUN_CALL_REGION_ID=cn-hangzhou
ALIYUN_CALL_CALLED_SHOW_NUMBER=
ALIYUN_CALL_TTS_CODE=
ALIYUN_CALL_PLAY_TIMES=2
ALIYUN_CALL_TEMPLATE_CODE=external_medical_followup
ALIYUN_CALL_CALLBACK_SECRET=
